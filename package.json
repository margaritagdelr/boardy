{
  "name": "boardy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Centro de mando personal: dashboard de links, inventario de cuentas y scope-tracker.",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta --raw \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --ignore data --ignore .boardy-secrets server/server.ts",
    "build": "tsc -b && vite build",
    "start": "tsx server/server.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.460.0",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
